DJANGO_SECRET_KEY=replace_with_a_long_random_secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.kepoli.com,kepoli.com,admin.kepoli.com,.kepoli.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://kepoli.com,https://admin.kepoli.com,https://*.kepoli.com
DJANGO_CORS_ALLOWED_ORIGINS=https://kepoli.com,https://admin.kepoli.com

POSTGRES_DB=kepoli_platform
POSTGRES_USER=kepoli_user
POSTGRES_PASSWORD=replace_with_a_long_password
DATABASE_URL=postgresql://kepoli_user:replace_with_a_long_password@postgres:5432/kepoli_platform

REDIS_URL=redis://redis:6379/0
PUBLIC_MENU_BASE_URL=https://kepoli.com
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_DOMAIN=.kepoli.com
DJANGO_CSRF_COOKIE_DOMAIN=.kepoli.com
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_PROXY_SSL_HEADER=True
DJANGO_DEFAULT_FROM_EMAIL=noreply@kepoli.com
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_SUPERADMIN_EMAIL=admin@kepoli.com
DJANGO_SUPERADMIN_PASSWORD=replace_with_a_strong_admin_password
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

VITE_API_BASE_URL=https://api.kepoli.com/api
VITE_ADMIN_API_BASE_URL=https://api.kepoli.com/api
VITE_APP_NAME=Kepoli Menu
VITE_MAPS_URL=https://maps.google.com
VITE_CONTACT_PHONE=
VITE_CONTACT_MESSAGE=Hello, I would like to place an order.
