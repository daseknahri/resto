VITE_API_BASE_URL=auto
VITE_ADMIN_API_BASE_URL=auto
VITE_PLATFORM_PUBLIC_HOSTS=localhost,127.0.0.1
VITE_APP_NAME=Resto Menu
VITE_MAPS_URL=https://maps.google.com
VITE_CONTACT_PHONE=+15551234567
VITE_CONTACT_MESSAGE=Hello, I would like to place an order.

# ── Sentry error tracking (optional) ─────────────────────────────────────────
# Leave blank to disable.  Set these in Coolify / CI for production builds.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
# Performance tracing sample rate: 0 = off, 0.1 = 10%, 1.0 = 100%
VITE_SENTRY_TRACES_SAMPLE_RATE=0
# Session Replay sample rate (0 = off)
VITE_SENTRY_REPLAYS_SESSION_RATE=0
# Build version tag (set by CI, e.g. git SHA or semver)
VITE_APP_VERSION=
