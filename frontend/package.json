{
  "name": "resto-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify:i18n": "node scripts/verify-i18n.mjs && node scripts/verify-i18n-usage.mjs",
    "verify:i18n-usage": "node scripts/verify-i18n-usage.mjs",
    "lint": "eslint \"src/**/*.{js,vue}\" --max-warnings=0",
    "format": "prettier -c \"src/**/*.{js,vue,css}\"",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:critical": "playwright test tests/e2e/critical-saas-flow.spec.js",
    "e2e:mobile": "playwright test tests/e2e/mobile-breakpoint-regression.spec.js",
    "e2e:install": "playwright install chromium"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@sentry/vue": "^8.38.0",
    "axios": "1.18.0",
    "leaflet": "^1.9.4",
    "pinia": "2.2.6",
    "qrcode": "^1.5.4",
    "vue": "3.5.13",
    "vue-router": "4.4.5"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.6",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/eslint-config-prettier": "9.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.4",
    "eslint-plugin-vue": "9.29.0",
    "jsdom": "^25.0.1",
    "postcss": "8.5.15",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.13",
    "vite": "8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "3.2.6",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1"
  }
}
