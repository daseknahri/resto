{
  "name": "resto-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,vue}\" --max-warnings=0",
    "format": "prettier -c \"src/**/*.{js,vue,css}\"",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:critical": "playwright test tests/e2e/critical-saas-flow.spec.js",
    "e2e:mobile": "playwright test tests/e2e/mobile-breakpoint-regression.spec.js",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@sentry/vue": "^8.38.0",
    "axios": "1.7.7",
    "leaflet": "^1.9.4",
    "pinia": "2.2.6",
    "qrcode": "^1.5.4",
    "vue": "3.5.13",
    "vue-router": "4.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "5.1.2",
    "@vue/eslint-config-prettier": "9.0.0",
    "autoprefixer": "10.4.20",
    "eslint": "9.10.0",
    "eslint-plugin-vue": "9.29.0",
    "postcss": "8.4.47",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.13",
    "vite": "5.4.8"
  }
}
