# Production starter template for a tenant namespace deployment on:
# - menu.yourdomain.com
# - admin.menu.yourdomain.com
# - *.menu.yourdomain.com

DJANGO_SECRET_KEY=replace_with_64_plus_random_chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=menu.yourdomain.com,admin.menu.yourdomain.com,.menu.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://menu.yourdomain.com,https://admin.menu.yourdomain.com,https://*.menu.yourdomain.com
DJANGO_CORS_ALLOWED_ORIGINS=https://menu.yourdomain.com,https://admin.menu.yourdomain.com

POSTGRES_DB=platform_db
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=replace_with_long_random_password
DATABASE_URL=postgresql://platform_user:replace_with_long_random_password@postgres:5432/platform_db

REDIS_URL=redis://redis:6379/0
PUBLIC_MENU_BASE_URL=https://menu.yourdomain.com
TENANT_DOMAIN_SUFFIX=menu.yourdomain.com
DJANGO_PUBLIC_SCHEMA_HOSTS=menu.yourdomain.com,admin.menu.yourdomain.com

DJANGO_MEDIA_STORAGE_BACKEND=local
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_ADDRESSING_STYLE=auto
AWS_S3_SIGNATURE_VERSION=
AWS_QUERYSTRING_AUTH=True
AWS_QUERYSTRING_EXPIRE=900
AWS_MEDIA_LOCATION=media
AWS_S3_OBJECT_CACHE_CONTROL=

DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_DOMAIN=.menu.yourdomain.com
DJANGO_CSRF_COOKIE_DOMAIN=.menu.yourdomain.com
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_PROXY_SSL_HEADER=True

DJANGO_DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DJANGO_SERVER_EMAIL=noreply@yourdomain.com
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.yourprovider.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=your_smtp_user
DJANGO_EMAIL_HOST_PASSWORD=replace_with_smtp_password
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_TIMEOUT=10
DJANGO_EMAIL_FAIL_SILENTLY=False
DJANGO_EMAIL_LOG_LEVEL=INFO

DJANGO_SUPERADMIN_EMAIL=admin@yourdomain.com
DJANGO_SUPERADMIN_PASSWORD=replace_with_strong_admin_password

DJANGO_LOG_FORMAT=json
DJANGO_REQUEST_LOG_LEVEL=INFO
DJANGO_PROVISIONING_LOG_LEVEL=INFO
DJANGO_SECURITY_LOG_LEVEL=WARNING
ADMIN_AUDIT_RETENTION_DAYS=180

DJANGO_SENTRY_DSN=
DJANGO_SENTRY_ENVIRONMENT=production
DJANGO_SENTRY_RELEASE=
DJANGO_SENTRY_TRACES_SAMPLE_RATE=0
DJANGO_SENTRY_SEND_PII=False
DJANGO_SENTRY_CAPTURE_THROTTLE=False
DJANGO_SENTRY_THROTTLE_MIN_WAIT_SECONDS=30

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

VITE_API_BASE_URL=auto
VITE_ADMIN_API_BASE_URL=auto
VITE_PLATFORM_PUBLIC_HOSTS=menu.yourdomain.com,admin.menu.yourdomain.com
VITE_APP_NAME=Your App Name
VITE_MAPS_URL=https://maps.google.com
VITE_CONTACT_PHONE=
VITE_CONTACT_MESSAGE=Hello, I would like to place an order.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
