# Backend environment template
# IMPORTANT: replace DJANGO_SECRET_KEY with a real random value in production.
# Generate one: python -c "import secrets; print(secrets.token_hex(50))"
# "change-me" is intentionally rejected by settings.py when DEBUG=False.
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://*.localhost:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://demo.localhost:5173
DATABASE_URL=postgresql://user:pass@localhost:5432/resto
REDIS_URL=redis://localhost:6379/0
PUBLIC_MENU_BASE_URL=http://demo.localhost:5173
TENANT_DOMAIN_SUFFIX=
DJANGO_PUBLIC_SCHEMA_HOSTS=localhost,127.0.0.1
DJANGO_MEDIA_STORAGE_BACKEND=local
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_ADDRESSING_STYLE=auto
AWS_S3_SIGNATURE_VERSION=
AWS_QUERYSTRING_AUTH=True
AWS_QUERYSTRING_EXPIRE=900
AWS_MEDIA_LOCATION=media
AWS_S3_OBJECT_CACHE_CONTROL=
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com
DJANGO_SERVER_EMAIL=noreply@example.com
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=25
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=False
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_TIMEOUT=10
DJANGO_EMAIL_FAIL_SILENTLY=True
DJANGO_EMAIL_LOG_LEVEL=INFO
ADMIN_AUDIT_RETENTION_DAYS=180
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

# ── HTTPS / admin hardening ───────────────────────────────────────────────────
# Change DJANGO_ADMIN_URL to an unguessable path in production, e.g.
# "internal-mgmt-abc123/"  (must end with /).
DJANGO_ADMIN_URL=admin/
# SSL redirect — leave False here; set to True in production (behind HTTPS proxy)
DJANGO_SECURE_SSL_REDIRECT=False
# HSTS — start with 3600 (1 hour) in staging; bump to 31536000 (1 year) later
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_REFERRER_POLICY=strict-origin-when-cross-origin

# ── Sentry error tracking (optional) ─────────────────────────────────────────
# Leave blank to disable.  Set in Coolify for production.
DJANGO_SENTRY_DSN=
DJANGO_SENTRY_ENVIRONMENT=production
# Performance tracing: 0.0 = off, 0.1 = 10%, 1.0 = 100%
DJANGO_SENTRY_TRACES_SAMPLE_RATE=0.0
# Set to True to include user PII (email, IP) in error reports
DJANGO_SENTRY_SEND_PII=False
# Release tag — set by CI (e.g. git SHA or semver)
DJANGO_SENTRY_RELEASE=
