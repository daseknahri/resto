# Backend environment template
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://*.localhost:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://demo.localhost:5173
DATABASE_URL=postgresql://user:pass@localhost:5432/resto
REDIS_URL=redis://localhost:6379/0
PUBLIC_MENU_BASE_URL=http://demo.localhost:5173
DJANGO_PUBLIC_SCHEMA_HOSTS=localhost,127.0.0.1
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
ADMIN_AUDIT_RETENTION_DAYS=180
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
